# Server
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (replace <YOUR_IP> with your machine's LAN IP)
DATABASE_URL=postgresql://postgres:123456@localhost::5432/ShopSpa
SECRET_KEY=shophub-secret-key-2026

# Frontend URL for CORS and PayPal redirects (replace <YOUR_IP>)
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# PayPal (optional overrides; defaults derive from FRONTEND_URL)
PAYPAL_CLIENT_ID=your-paypal-sandbox-client-id
PAYPAL_CLIENT_SECRET=your-paypal-sandbox-client-secret
PAYPAL_RETURN_URL=http://localhost:5173/payment/paypal/success
PAYPAL_CANCEL_URL=http://localhost:5173/payment/paypal/cancel
